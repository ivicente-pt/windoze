#!/usr/bin/env bash
set -euo pipefail

# user-menu v1.1 - 2026-03-24

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB"
[[ "$AEVH_LIB_LOADED" != "1" ]] && { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

TITLE="Gestão de utilizadores"
MSG_CONFIRM="Esta operação vai APAGAR todos os dados locais do utilizador e repor as definições originais.\n\nContinuar?"
MANAGE="${AEVH_BIN:-/opt/aevh/bin}/user-manage"

run_user_action() {
    local action="${1:-}" user="${2:-}" label="${3:-}"
    
    case "$action" in
        reset)
            if confirm "$MSG_CONFIRM" "Atenção: Reset $user"; then
                "$MANAGE" reset "$user"
                usermod -c "$label" "$user"
                dialog --title "Sucesso" --msgbox "O utilizador $user foi reposto." 6 45
            else
                log_info "Reset de $user cancelado pelo administrador."
            fi
            ;;
        save)
            "$MANAGE" save "$user"
            dialog --title "Sucesso" --msgbox "Perfil de $user guardado com sucesso." 6 45
            ;;
    esac
}

main() {
    get_root "$@"
    local opt
    while true; do
        if ! opt=$(dialog --title "$TITLE" --menu "Escolha a ação para os perfis locais:" 15 55 5 \
            1 "Reset do aluno" \
            2 "Salvar o perfil do aluno" \
            3 "Reset do professor" \
            4 "Salvar o perfil do professor" \
            0 "Sair" 3>&1 1>&2 2>&3); then
            log_bye "Menu encerrado"
        fi

        case $opt in
            1) run_user_action reset aluno "Aluno" ;;
            2) run_user_action save aluno "" ;;
            3) run_user_action reset professor "Professor" ;;
            4) run_user_action save professor "" ;;
            0) log_bye "Saída selecionada." ;;
        esac
    done
}

main "$@"
