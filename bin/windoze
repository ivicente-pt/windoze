#!/usr/bin/env bash
set -euo pipefail

# windoze v1.6 2026-03-24

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || { echo "Falha a carregar lib AEVH"; exit 1; }

PKG_BASE=(
        sudo fail2ban btop htop p7zip-full unrar-free pigz localepurge rsync earlyoom
        zram-tools xcape molly-guard numlockx openssh-server wget curl dialog unattended-upgrades jq
        alsa-utils cups bleachbit
    )
PKG_GUI=(
        ttf-mscorefonts-installer vlc libnotify-bin libglib2.0-bin fonts-noto-color-emoji
        task-xfce-desktop xfce4 xfce4-goodies xfce4-whiskermenu-plugin fonts-croscore
        gtk2-engines-murrine network-manager-gnome xfce4-panel-profiles plank dbus-x11
        gnome-calculator xfconf xfce4-power-manager bleachbit mugshot
        mesa-utils picom
    )
PKG_WINE=( wine wine64-tools winetricks wine-binfmt binfmt-support wine32 wine32-preloader )
PKG_DM=( lightdm slick-greeter lightdm-settings )
PKG_OFFICE=( libreoffice libreoffice-l10n-pt libreoffice-help-pt )
PKG_BROWSERS=( firefox-esr firefox-esr-l10n-pt-pt chromium )
PKG_THEMES=( libsass1 sassc )
PKG_PRINT=( cups )
PKG_OCS=( ocsinventory-agent )

generate_apt_list() {
    version="${1:-}"
    [[ "$version" != "bookworm" && "$version" != "trixie" ]] && return 1
    cat << EOF
deb http://deb.debian.org/debian/ "${version}" main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian/ "${version}" main contrib non-free non-free-firmware
deb http://security.debian.org/debian-security "${version}"-security main contrib non-free non-free-firmware
deb-src http://security.debian.org/debian-security "${version}"-security main contrib non-free non-free-firmware
deb http://deb.debian.org/debian/ "${version}"-updates main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian/ "${version}"-updates main contrib non-free non-free-firmware
EOF
}

generate_unattended_upgrades() {
    version="${1:-}"
    [[ "$version" != "bookworm" && "$version" != "trixie" ]] && return 1
    cat << EOF
Unattended-Upgrade::Origins-Pattern {
    "origin=Debian,codename=${version}-security,label=Debian-Security";
    "origin=Debian,codename=${version},label=Debian-Security";
    "origin=Debian,codename=${version},label=Debian";
    "origin=Debian,codename=${version}-updates,label=Debian";
};

Unattended-Upgrade::Package-Blacklist {
};

Unattended-Upgrade::Automatic-Reboot "false";
Unattended-Upgrade::InstallOnShutdown "true";
EOF
}

generate_crontab() {
    cat << EOF
17 */2    *         *   * /opt/aevh/bin/auto-apt-proxy
29  17    *         *   * /opt/aevh/bin/shutdown-spread
59  18,23 *         *   * /opt/aevh/bin/shutdown-spread
*    *    *         *   * /opt/aevh/bin/shutdown-notify
15  09    *         * 6,7 /opt/aevh/bin/shutdown-spread 5
16  09    1 1,5,11,12   * /opt/aevh/bin/shutdown-spread 5
16  09   25      4,12   * /opt/aevh/bin/shutdown-spread 5
16  09    5        10   * /opt/aevh/bin/shutdown-spread 5
16  09    8	       12   * /opt/aevh/bin/shutdown-spread 5
16  09   10         6   * /opt/aevh/bin/shutdown-spread 5
00 */4    *         8   * /opt/aevh/bin/shutdown-spread 5
EOF
}

setup_repos() {
    local list="/etc/apt/sources.list" debian="${1:-}"
    log_info "A configurar repositórios"
    [[ "$debian" != "bookworm" && "$debian" != "trixie" ]] && log_critical "Versão não suportada: $debian"
    make_file_backup "$list"
    generate_apt_list "$debian" > "$list"
    log_info "A atualizar repositórios"
    apt_update && log_info "Repositórios configurados"
}

install_base() {
    log_info "A instalar a base do sistema"
    debian="$(get_debian_version)"
    setup_repos "$debian"
    generate_unattended_upgrades "$debian" > /etc/apt/apt.conf.d/50unattended-upgrades
    apt_install debconf-utils
    echo "unattended-upgrades unattended-upgrades/enable_auto_updates boolean true" | debconf-set-selections
    echo "localepurge localepurge/nopurge multiselect pt, pt_PT, pt_PT.UTF-8, en, en_US, en_US.UTF-8" | debconf-set-selections
    echo "localepurge localepurge/use-dpkg-feature boolean true" | debconf-set-selections
    echo "localepurge localepurge/mandelete boolean true" | debconf-set-selections
    apt_install "${PKG_BASE[@]}"
    apt_cmd autopurge
    log_info "Instalação base concluída."
}

install_wine() {
    log_info "A instalar subsistema Windows"
    dpkg --add-architecture i386
    apt_update
    apt_install "${PKG_WINE[@]}"
    update-binfmts --import wine >/dev/null 2>&1
    log_info "Subsistema Windows instalado"
}

copy_file_dir() {
    local src="${1:-}" dst="${2:-}"
    [[ -f "$src" ]] || return 0
    [[ -f "$dst" ]] && return 1
    mkdir -p "$dst" || return 1
    cp -a "$src" "$dst" || return 1
    return 0
}

install_lightdm(){
    echo "lightdm shared/default-x-display-manager select lightdm" | debconf-set-selections
    apt_install "${PKG_DM[@]}"
    mkdir -p /etc/lightdm/lightdm.conf.d
    copy_file_dir "/opt/aevh/conf/lightdm/lightdm.conf" "/etc/lightdm"
    copy_file_dir "/opt/aevh/conf/lightdm/slick-greeter.conf" "/etc/lightdm"
    echo "/usr/sbin/lightdm" > /etc/X11/default-display-manager
    DEBIAN_FRONTEND=noninteractive dpkg-reconfigure lightdm
    systemctl enable lightdm
    log_info "LightDM configurado com sucesso."
}

install_gui() {
    local pkg
    is_debian12 && pkg=( libgl1-mesa-glx )
    is_debian13 && pkg=( libgl1 libglx-mesa0 )
    echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections
    apt_install "${PKG_GUI[@]}" "${pkg[@]}"
    log_info "Interface gráfica instalada com sucesso"
}

install_ocs() {
    echo "ocsinventory-agent ocsinventory-agent/method select local" | debconf-set-selections
    echo "ocsinventory-agent ocsinventory-agent/server string localhost" | debconf-set-selections
    apt_install "${PKG_OCS[@]}"
    copy_file_dir "$AEVH_CONF/ocsinventory/ocsinventory-agent.cfg" "/etc/ocsinventory"
    command -v ocsinventory-agent >/dev/null && ocsinventory-agent --force >/dev/null 2>&1 &
    log_info "OCS Inventory instalado"
}

# Instalar o crontab do root com as definições para encerrar ao fim do dia, fim de semana, etc
install_crontab() {
    log_info "A instalar o novo crontab"
    local current_cron new_lines
    uninstall_crontab
    current_cron=$(crontab -l 2>/dev/null)
    new_lines=$(generate_crontab)
    if [[ -z "$current_cron" ]]; then
        final_cron="$new_lines"
    else
        final_cron=$(printf "%s\n%s" "$current_cron" "$new_lines")
    fi
    echo "$final_cron" | crontab -
}

download_file() {
    local fname url="${1:-}" dir
    [[ -z "$url" ]] && return 1
    fname=$(basename "$url")
    dir="$(mktemp -d)"
    if ! wget --timeout=10 --tries=4 "$url" -O "$dir/$fname"; then
        log_warn "Não consigo transferir $url"
        return 1
    fi
    echo "$dir/$fname"
    return 0
}

install_deb() {
    local deb="${1:-}"
    [[ -z "$deb" ]] && return 1
    apt_install "$deb" || return 1
    log_info "Sucesso: '$deb' instalado."
    return 0
}

install_url() {
    local url="${1:-}" fname
    [[ -z "$url" ]] && return 1
    fname="$(download_file "$url")" || return 1
    install_deb "$fname" || return 1
    return 0
}

install_themes() {
    log_info "A instalar wallpapers"
    local url tmp_dir theme_dir src="/opt/aevh/data/themes/Fluent.tgz"
    local bg_dst="/usr/share/backgrounds/Windoze"
    [[ -d "$bg_dst" || -L "$bg_dst" ]] && rm -rf "$bg_dst"
    ln -sfn "/opt/aevh/data/wallpaper" "$bg_dst"
    apt_install "${PKG_THEMES[@]}"

    tmp_dir=$(mktemp -d)
#    trap 'rm -rf "$tmp_dir"' RETURN

    if [[ -f "$src" ]]; then
        tar xzf "$src" -C "$tmp_dir"
        theme_dir="$tmp_dir"/Fluent
        if [[ -n "$theme_dir" && -d "$theme_dir" ]]; then 
            log_info "A instalar Fluent..."
            pushd "$theme_dir" >/dev/null
            ./install.sh --tweaks round solid square  -s compact 
            popd >/dev/null
            log_info "Tema Fluent instalado"
        else
            log_warn "Não consegui instalar o tema Fluent"
        fi
    fi

    url="https://github.com/luisrguerra/fluent11-icon-theme/releases/download/0.5.2/wow64-0.5.2.deb"
    pkg_installed wow64-icon-themes || install_url "$url"
    chmod -R a+r /usr/share/themes
    chmod -R a+r /usr/share/icons
    chmod -R a+r /usr/share/backgrounds
}

install_browsers() {
    log_info "A instalar browsers"
    apt_install "${PKG_BROWSERS[@]}"
    # local chrome_url="https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"
    # install_deb "$chrome_url" google-chrome-stable
}

# Instala o Office: OnlyOffice
install_office() {
    log_info "A instalar Office"
    apt_install "${PKG_OFFICE[@]}"
    pkg_installed onlyoffice-desktopeditors && return 0
    local oo_url="https://download.onlyoffice.com/install/desktop/editors/linux/onlyoffice-desktopeditors_amd64.deb"
    install_url "$oo_url"
}

uninstall_browsers() {
    remove_pkg google-chrome-stable "${PKG_BROWSERS[@]}"
    local list="/etc/apt/sources.list.d/google-chrome.list"
    [[ -f "$list" ]] || return 0
    rm -f "$list"
}

uninstall_office() {
    remove_pkg onlyoffice-desktopeditors "${PKG_OFFICE[@]}"
}

uninstall_lightdm() {
    systemctl stop lightdm 2>/dev/null || true
    systemctl disable lightdm 2>/dev/null || true
    apt_purge "${PKG_DM[@]}" && rm -rf /etc/lightdm/
}

uninstall_gui() {
    apt_purge "${PKG_GUI[@]}"
}

uninstall_ocs() {
    apt_purge "${PKG_OCS]}"
    rm -rf /etc/ocsinventory /var/lib/ocsinventory-agent
}

uninstall_crontab() {
    local current to_remove updated
    current=$(crontab -l 2>/dev/null)
    [[ -z "$current" ]] && return 0
    to_remove="$(generate_crontab)"
    [[ -z "$to_remove" ]] && return 0
    updated=$(echo "$current" | grep -vFx "$to_remove")
    if [[ -z "$updated" ]]; then
        crontab -r 2>/dev/null
    else
        echo "$updated" | crontab -
    fi
}

# Remove os temas e papel de parede
uninstall_themes() {
    apt_purge wow64-icon-themes "${PKG_THEMES[@]}"
    rm -rf /usr/share/themes/Fluent /usr/share/backgrounds/Windoze
    gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true
}

optimize() {
    local override_dir="/etc/systemd/system/preload.service.d"
    if [[ "$(get_disk_type /)" == "HDD" ]]; then 
        apt_install preload
        mkdir -p "$override_dir"
        copy_check "$/opt/aevh/conf/systemd/override.conf" "$override_dir"
    else
        dpkg_installed preload && apt_purge preload
    fi

    log_info "A configurar serviços systemd"
    systemctl daemon-reload
    systemctl restart --no-block preload

    # Configurar serviços
    systemctl disable --now NetworkManager-wait-online.service ModemManager.service 2>/dev/null
    systemctl mask --now avahi-daemon.service avahi-daemon.socket e2scrub_reap.service 2>/dev/null

    local zram_config="/etc/default/zramswap"
    systemctl stop zramswap 2>/dev/null
    set_config_value "$zram_config" "ALLOCATION_STRATEGY" "percent"
    set_config_value "$zram_config" "PERCENT" "50"
    set_config_value "$zram_config" "COMPRESSION_ALGORITHM" "lz4"
    set_config_value "$zram_config" "PRIORITY" "100"
    systemctl restart zramswap

    local sys_file="/etc/sysctl.d/99-swappiness.conf"
    mkdir -p "$(dirname "$sys_file")"
    [[ ! -f "$sys_file" ]] && touch "$sys_file" 
    set_config_value "$sys_file" "vm.swappiness" "10"
    sysctl -p "$sys_file" >/dev/null

    # NetworkManager-wait-online - não é preciso esperar por ligação à rede
    # ModemManager - serve para gerir modems 3G/4G
    # avahi-daemon avahi-daemon - serve para localizar partilhas na rede
    # e2scrub - não precisa correr em todos os boot, só 1 vez por semana
    # o bluetooth
    #systemctl disable --now bluetooth.service
  
    # Logs
    set_config_value "/etc/systemd/journald.conf" "SystemMaxUse" "50M"
    set_config_value "/etc/systemd/journald.conf" "Storage" "volatile"
    (
        journalctl --vacuum-time=2d > /dev/null 2>&1
        systemctl restart systemd-journald
    ) &
    sed -i 's/^[# ]*MODULES=.*/MODULES=dep/' "/etc/initramfs-tools/initramfs.conf"
    update-initramfs -u
    log_info "Serviços otimizados"
}

usage() {
    cat << EOF
Uso: $(basename "$0") <comando> [componente]
Comandos:
  install   [base, gui, ocs, crontab, themes, browsers, office, logrotate]
  remove    [gui, ocs, crontab, themes, browsers, office, logrotate]
  clean     Limpeza de sistema e correção do APT.
  full      Instalação COMPLETA (Transforma Debian 12/13 em Windoze).
  
Exemplos:
  $(basename "$0") install gui
  $(basename "$0") remove themes
EOF
    exit 1
}

main() {
    local comm="${1:-}" param="${2:-}"
    [[ -z "$comm" ]] && usage
    get_root
    case "$comm" in
#        "clean") clean_system ;;
        "install")
            case "$param" in
                "base") install_base ;;
                "gui") install_gui ;;
                "office") install_office ;;
                "ocs") install_ocs ;;
                "crontab") install_crontab ;;
                "themes") install_themes ;;
                "browsers") install_browsers ;;
                *) log_error "$0 $comm $param - Opção inválida" ;;
            esac
        ;;
        "remove")
            case "$param" in
                "browsers") uninstall_browsers ;;
                "office") uninstall_office ;;
                "gui") uninstall_gui ;;
                "ocs") uninstall_ocs ;;
                "crontab") uninstall_crontab ;;
                "themes") uninstall_themes ;;
                *) log_error "$0 $1 $2 - Opção inválida" ;;
            esac
        ;;
        "full")
            install_base
            install_gui
            install_ocs
            install_crontab
            install_themes
            install_splash
            install_browsers
            install_office
            optimize
            log_info "Instalação concluída"
            ;;
        *)
            log_error "Comando desconhecido: $comm"
            usage
        ;;
    esac
}

main "$@"
