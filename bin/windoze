optimize() {
    # preload
    if [[ $(get_disk_type /) == "HDD" ]]; then 
        apt_install preload
        OVERRIDE_DIR="/etc/systemd/system/preload.service.d"
        mkdir -p "$OVERRIDE_DIR"
        copy_check "$AEVH_CONF/systemd/override.conf" "$OVERRIDE_DIR"
    else
        dpkg -s preload &> /dev/null && apt_cmd remove preload
    fi

    log_info "A configurar serviços systemd"
    systemctl daemon-reload
    systemctl restart --no-block preload

    # Configurar serviços
    systemctl disable --now NetworkManager-wait-online.service ModemManager.service 2>/dev/null
    systemctl mask --now avahi-daemon.service avahi-daemon.socket e2scrub_reap.service 2>/dev/null
    systemctl stop zramswap 2>/dev/null
    copy_check "$AEVH_CONF/default/zramswap" /etc/default/
    systemctl enable --now e2scrub_all.timer zramswap
    sysctl vm.swappiness=10 >/dev/null
    local sysctl="/etc/sysctl.conf"
    [[ ! -f "$sysctl" ]] && touch "$sysctl" 
    set_config_value "$sysctl" "vm.swappiness" 10

    # NetworkManager-wait-online - não é preciso esperar por ligação à rede
    # ModemManager - serve para gerir modems 3G/4G
    # avahi-daemon avahi-daemon - serve para localizar partilhas na rede
    # e2scrub - não precisa correr em todos os boot, só 1 vez por semana

    # o bluetooth
    #systemctl disable --now bluetooth.service
  
    # Logs
    set_config_value "/etc/systemd/journald.conf" "SystemMaxUse" "50M"
    set_config_value "/etc/systemd/journald.conf" "Storage" "volatile"
    (
        journalctl --vacuum-time=2d > /dev/null 2>&1
        systemctl restart systemd-journald
    ) &
    sed -i 's/^MODULES=.*/MODULES=dep/' "/etc/initramfs-tools/initramfs.conf"
    update-initramfs -u
    log_info "Serviços otimizados"
}

# Instalar e atualizar os pacotes essenciais
install_base() {
    log_info "A instalar a base do sistema"
    local pkg_base=(
        sudo fail2ban btop htop p7zip-full unrar-free pigz localepurge rsync earlyoom pipewire-audio zram-tools xcape
        molly-guard numlockx openssh-server wget dialog unattended-upgrades jq espeak-ng alsa-utils cups bleachbit
    )
    [[ $(get_disk_type /) == "HDD" ]] && pkg_base+=(preload) 
    # se ficar disponível no debian, acrescentar: boot-repair
    info_exec "A configurar os repositórios" enable_repos
    info_exec "A instalar debconf-utils" apt_install debconf-utils
    echo "unattended-upgrades unattended-upgrades/enable_auto_updates boolean true" | debconf-set-selections
    echo "localepurge localepurge/nopurge multiselect pt, pt_PT, pt_PT.UTF-8, en, en_US, en_US.UTF-8" | debconf-set-selections
    echo "localepurge localepurge/use-dpkg-feature boolean true" | debconf-set-selections
    echo "localepurge localepurge/mandelete boolean true" | debconf-set-selections
    info_exec "A instalar pacotes base" apt_install "${pkg_base[@]}"
    info_exec "A configurar o master" install_master
    info_exec "A instalar drivers da Konica" install_konica
    log_info "A configurar atualizações automáticas"
    local upgrades="$AEVH_CONF/apt/50unattended-upgrades"
    if [[ -f "$upgrades" ]]; then
        copy_check "$upgrades" "/etc/apt/apt.conf.d/"
    else
        log_warn "Ficheiro $upgrades não encontrado. Usando predefinição."
    fi
    info_exec "A remover pacotes obsoletos" apt_cmd autopurge -y
    info_exec "A otimizar o sistema" optimize
    log_info "Instalação base concluída."
}


# Install Wine
install_wine() {
    log_info "A instalar subsistema Windows"
    local pkg_wine=( wine wine64-tools winetricks wine-binfmt binfmt-support wine32 wine32-preloader )
    dpkg --add-architecture i386
    apt_update
    apt_install "${pkg_wine[@]}"
    update-binfmts --import wine >/dev/null 2>&1
    log_info "Subsistema Windows instalado"
}

# Instalar e configurar o lightdm
install_lightdm(){
    echo "lightdm shared/default-x-display-manager select lightdm" | debconf-set-selections
    apt_install lightdm slick-greeter lightdm-settings
    mkdir -p /etc/lightdm/lightdm.conf.d
    local src="$AEVH_CONF/lightdm"
    if [[ -d "$src" ]]; then
        log_info "A copiar configurações do LightDM..."
        cp -a "$src/." /etc/lightdm/ || log_warn "Erro ao copiar configurações do LightDM"
    else
        log_warn "Pasta de configuração $src não encontrada. A usar predefinições."
    fi
    echo "/usr/sbin/lightdm" > /etc/X11/default-display-manager
    DEBIAN_FRONTEND=noninteractive dpkg-reconfigure lightdm
    systemctl enable lightdm
    log_info "LightDM configurado com sucesso."
}

# Instalar a interface gráfica: Cinnamon ou XFCE
install_gui() {
    local pkg_gui=(
        ttf-mscorefonts-installer vlc libnotify-bin libglib2.0-bin fonts-noto-color-emoji 
    )
    local pkg_gui_xfce4=(
        task-xfce-desktop xfce4 xfce4-goodies xfce4-whiskermenu-plugin fonts-croscore 
        gtk2-engines-murrine network-manager-gnome xfce4-panel-profiles plank dbus-x11 
        gnome-calculator xfconf xfce4-power-manager bleachbit mugshot 
        mesa-utils picom 
        # xfce4-docklike-plugin nemo nemo-fileroller
    )
    pkg_gui_cinnamon=( task-cinnamon-desktop )

    if is_xfce4; then
        pkg_gui+=( "${pkg_gui_xfce4[@]}" )
        is_debian12 && pkg_gui+=( libgl1-mesa-glx )
        is_debian13 && pkg_gui+=( libgl1 libglx-mesa0 )
    else
        pkg_gui+=( "${pkg_gui_cinnamon[@]}" )
    fi

    log_info "A instalar a interface gráfica..."
    echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections
    info_exec "A instalar os pacotes" apt_install "${pkg_gui[@]}"
    install_wine
    install_lightdm
    log_info "Interface gráfica instalada com sucesso"
}


# Instalar o OCS Inventory agent
install_ocs() {
    echo "ocsinventory-agent ocsinventory-agent/method select local" | debconf-set-selections
    echo "ocsinventory-agent ocsinventory-agent/server string localhost" | debconf-set-selections
    info_exec "A instalar o OCS Inventory agent" apt_install ocsinventory-agent
    local src="$AEVH_CONF/ocsinventory/ocsinventory-agent.cfg"
    local dest="/etc/ocsinventory"
    mkdir -p "$dest"
    copy_check "$src" "$dest/"
    command -v ocsinventory-agent >/dev/null && ocsinventory-agent --force >/dev/null 2>&1 &
}

# Instalar o crontab do root com as definições para encerrar ao fim do dia, fim de semana, etc
install_crontab() {
    log_info "A criar crontab de root"
    local src="CONF/crontab.root"
    [[ -f "$src" ]] && crontab -u root "$src"
    # info_exec "A instalar cron.daily" cp "$AEVH_CONF/cron.daily"/* /etc/cron.daily/
}

# Instala os temas e papel de parede
install_themes() {
    log_info "A configurar temas visuais"
    log_info "A instalar wallpapers"
    local bg_dst="/usr/share/backgrounds/Windoze"
    [[ -d "$bg_dst" || -L "$bg_dst" ]] && rm -rf "$bg_dst"
    ln -sfn "$AEVH_DATA/wallpaper" "$bg_dst"
    info_exec "A instalar dependências" apt_install libsass1 sassc
    
    local tmpdir
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' RETURN

    # Instalar o tema Fluent
    local src="$AEVH_DATA/themes/Fluent.tgz"
    if [[ -f "$src" ]]; then
        info_exec "A instalar tema Fluent" tar xzf "$src" -C "$tmpdir"
        local theme_dir="$tmpdir"/Fluent
        
        if [[ -n "$theme_dir" && -d "$theme_dir" ]]; then 
            log_info "A instalar Fluent..."
            pushd "$theme_dir" >/dev/null
            ./install.sh --tweaks round solid square  -s compact 
            popd >/dev/null
            log_info "Tema Fluent instalado"
        else
            log_warn "Não consegui instalar o tema Fluent"
        fi
    fi
    
    local wow64_url="https://github.com/luisrguerra/fluent11-icon-theme/releases/download/0.5.2/wow64-0.5.2.deb"
    info_exec "A instalar ícones" install_deb "$wow64_url" wow64-icon-themes  
    chmod -R a+r /usr/share/themes
    chmod -R a+r /usr/share/icons
    chmod -R a+r /usr/share/backgrounds
}

# Instala o boot splash do Win10
install_splash() {
    log_info "A instalar animação de boot"
    apt_install plymouth plymouth-themes plymouth-x11
    local tmpdir osid
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' RETURN
    
    local src="$AEVH_DATA/plymouth/win10.tar.gz"
    local dest="/usr/share/plymouth/themes"
    log_info "A configurar plymouth"
    GRUB_FILE="/etc/default/grub"
    
    if is_hp7800; then
        local file="/etc/initramfs-tools/modules"
        local module="i915"
        if ! grep -Fxq "$module" "$file"; then
            echo "$module" >> "$file"
        fi
    fi
    
    if [[ -d "$dest"/win10 ]]; then
        log_info "Plymouth Win10 já instalado"
    else
        mkdir -p "$tmpdir/plymouth"
        tar xzf "$src" -C "$tmpdir/plymouth"
        warn_ok_exec "Não consegui instalar o tema plymouth" \
            "Tema plymouth instalado" \
            mv "$tmpdir"/plymouth/*/ "$dest"
    fi
    
    check "Não foi possível entrar no diretório $dest/win10" cd "$dest"/win10
    if [[ ! -f "/etc/initramfs-tools/conf.d/splash" ]] && [[ -f "splash" ]]; then cp splash /etc/initramfs-tools/conf.d/splash; fi

    # reduzir timeout do grub e ligar quiet splash
    set_config_value "$GRUB_FILE" "GRUB_TIMEOUT" "0"
    if ! grep -q '^GRUB_CMDLINE_LINUX_DEFAULT=".*splash.*"$' "$GRUB_FILE"; then
        log_info "O parâmetro 'splash' NÃO está presente em GRUB_CMDLINE_LINUX_DEFAULT. A adicionar..."
        # Adicionar 'splash' preservando outras opções
        sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT="\([^"]*\)"/GRUB_CMDLINE_LINUX_DEFAULT="\1 quiet splash"/' "$GRUB_FILE"
    fi
    warn_ok_exec "Falha ao atualizar o GRUB." "GRUB atualizado com sucesso." update-grub
    
    osid=$(get_config_value "/etc/os-release" "ID")
    if [[ "$osid" == "linuxmint" ]]; then
        update-alternatives --install "$dest/default.plymouth" default.plymouth "$dest/win10/win10.plymouth" 100
        update-alternatives --set default.plymouth "$dest/win10/win10.plymouth"
    else
    	check "Erro ao definir o tema do Plymouth: win10" plymouth-set-default-theme -R win10
    fi
    splash_test
    update-initramfs -u
}

# mostra o splash durante 10 segundos
splash_test() {
    log_info "A executar um teste de splash de 10 segundos..."
    plymouthd
    plymouth --show-splash
    for ((I=0; I<10; I++)); do
        sleep 1
        plymouth --update=test$I --progress
    done
    plymouth --quit
    reset
}

# Instalar um DEB $1=url para fazer o download, $2=nome do pacote instalado
install_deb () {
    [[ $# -ne 2 ]] && { log_error "install_debfile(): É preciso indicar dois parâmetros."; return 1; }
    local url="$1"
    local pkg="$2"
    local debfile tmpdir tmpfile
    debfile=$(basename "$url")
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' RETURN
    tmpfile="$tmpdir/$debfile"
    
    dpkg-query -s "$pkg">/dev/null 2>&1 && {  log_info "Pacote $pkg já instalado"; return 0; }
    if ! wget --timeout=10 --tries=4 "$url" -O "$tmpfile"; then
        log_warn "Não consigo transferir $url, continuando com ficheiro offline"
        tmpfile="$AEVH_DATA/deb/$debfile"
    fi
    install_pkg "$tmpfile"
    sleep 1
    ! dpkg-query -s "$pkg" >/dev/null 2>&1 && { log_error "'$pkg' não ficou instalado corretamente."; return 1; }
    log_info "Sucesso: '$pkg' instalado."
}

# Instala o Browser: Firefox e Chrome
install_browsers() {
    log_info "A instalar browsers"
    apt_install firefox-esr firefox-esr-l10n-pt-pt
    local chrome_url="https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"
    install_deb "$chrome_url" google-chrome-stable
}

# Instala o Office: OnlyOffice
install_office() {
    log_info "A instalar Office"
    apt_install libreoffice libreoffice-l10n-pt libreoffice-help-pt
    local oo_url="https://download.onlyoffice.com/install/desktop/editors/linux/onlyoffice-desktopeditors_amd64.deb"
    install_deb "$oo_url" onlyoffice-desktopeditors
}

# Instala o software do SafeQ
install_ysoft() {
    local src="$AEVH_DATA/ysoft"
    [[ ! -d "$src" ]] && { log_error "Pasta $src não encontrada"; return 1; }
    local debfiles=(
    	"multiarch-support_2.27-3ubuntu1_amd64.deb"
        "libgnome-keyring-common_3.12.0-1build1_all.deb"
        "libgnome-keyring0_3.12.0-1build1_amd64.deb"
        "libcrafter_0.0.3_amd64.deb"
    # Estes são precisos no Debian 13?
    #	"libicu67_67.1-7_amd64.deb"
    #	"libwebp6_0.6.1-2.1+deb11u2_amd64.deb"
    #	"libqt5webkit5_5.212.0~alpha4-11_amd64.deb"
    #   "libqt5webkit5-fixed.deb"
        "ysoft-client_4.2_amd64.deb"
    )
    log_info "A instalar YSoft SafeQ"
    apt_install cups
    for deb in "${debfiles[@]}"; do
        install_debfile "$src/$deb"
    done
    apt_fix
    if [[ -n "$DISPLAY" ]]; then 
	log_info "A iniciar configuração gráfica"
	xhost local:root >/dev/null 2>&1
	if command -v dialog >/dev/null 2>&1; then
	    dialog --title "SafeQ" --msgbox "1. Adicionar a impressora sqport://10.0.0.6\n2. Usar o driver Bizhub\n3. Desligar encriptação" 0 0
	fi
       if command -v ysoft-client-settings >/dev/null; then
           ysoft-client-settings
        else
            log_warn "Executável 'ysoft-client-settings' não encontrado."
        fi
        xhost -local:root >/dev/null 2>&1
    else	
        log_warn "Ambiente gráfico não detetado. Configuração manual necessária:"
        echo "   -> Adicionar impressora: sqport://10.0.0.6 (Driver Bizhub)"
        echo "   -> Executar: ysoft-client-settings"
        echo "   -> Desligar encriptação."
    fi
    keywait
    log_info "É recomendado reiniciar o sistema."
}

# Apaga o Google chrome
remove_chrome() {
    log_info "A remover o Google Chrome"
    remove_pkg google-chrome-stable
    local repo_list="/etc/apt/sources.list.d/google-chrome.list"
    [[ ! -f "$repo_list" ]] && return 0
    rm -f "$repo_list"
    log_info "Repositório do Google Chrome removido."
}

# Apaga o OnlyOffice
remove_onlyoffice() { log_info "A remover OnlyOffice"; remove_pkg onlyoffice-desktopeditors; }

# Apaga o software do SafeQ
remove_ysoft() {
    local pkgs=(
        "ysoft-client" "libcrafter" "libgnome-keyring0" "libgnome-keyring-common"
        # "multiarch-support"
    )
    for pkg in "${pkgs[@]}"; do
        remove_pkg "$pkg"
    done
    log_info "A fazer uma limpeza"
    apt_cmd autopurge -y
    keywait
    dialog --title SafeQ --msgbox "É preciso reemover manualmente a impressora SafeQ" 0 0
}

# Elimina o lightdm
remove_lightdm() {
    systemctl stop lightdm 2>/dev/null || true
    systemctl disable lightdm 2>/dev/null || true
    apt_purge lightdm slick-greeter lightdm-settings && rm -rf /etc/lightdm/
}

# Eliminar a interface gráfica
remove_gui() {
    local pkg_gui=(
    # Wine e Ferramentas Base
        ttf-mscorefonts-installer wine wine64-tools winetricks wine-binfmt binfmt-support 
        vlc libnotify-bin libglib2.0-bin fonts-noto-color-emoji wine32 wine32-preloader
    
    # Ambiente XFCE e Utilitários
        task-xfce-desktop xfce4 xfce4-goodies xfce4-whiskermenu-plugin fonts-croscore 
        gtk2-engines-murrine network-manager-gnome xfce4-panel-profiles plank dbus-x11 
        gnome-calculator xfconf xfce4-power-manager bleachbit mugshot 
        mesa-utils libgl1-mesa-glx
        # xfce4-docklike-plugin nemo nemo-fileroller
    # Ambiente Cinnamon
        task-cinnamon-desktop
    )
    apt_purge "${pkg_gui[@]}"
    remove_lightdm
    apt_cmd autoremove
}

# Eliminar o OCS Inventory agent
remove_ocs() {
    apt_purge ocsinventory-agent
    rm -rf /etc/ocsinventory
    rm -rf /var/lib/ocsinventory-agent
}

# Elimina o crontab do root
remove_crontab() {
    crontab -r 2>/dev/null
}

# Remove os temas e papel de parede
remove_themes() {
    apt_purge wow64-icon-themes  
    rm -rf /usr/share/themes/Fluent
    rm -rf /usr/share/backgrounds/Windoze
    apt_purge libsass1 sassc
    gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true
}

# Remove  o boot splash (plymouth)
remove_splash() {
    local file="/etc/initramfs-tools/modules" module="i915"
    sed -i "/^$module$/d" "$file"

    apt_purge plymouth plymouth-themes plymouth-x11
    rm -rf /usr/share/plymouth/themes
    rm -rf /etc/initramfs-tools/conf.d/splash

    GRUB_FILE="/etc/default/grub"
    set_config_value "$GRUB_FILE" "GRUB_TIMEOUT" "5"
    if grep -q "splash" "$GRUB_FILE"; then
        log_info "A remover parâmetro 'splash' do GRUB..."
        sed -i -E 's/[[:space:]]*\bsplash\b//g' "$GRUB_FILE"
    fi
    #update-initramfs -u
    update-grub
}

# Elimina pacotes não autorizados
purge() {
    log_info "A corrigir o sistema"
    apt_fix
    local pkg_del=(
        "cheese*" "brasero*" "rhythmbox*" "sound-juicer*" "gnome-games" "hexchat*"
        "pidgin*" "remmina*" "transmission*" "evolution" "thunderbird*" "simple-scan*"
        "timeshift*" "popularity-contest" "installation-report" "task-mate-desktop"
        "task-kde-desktop" "task-lxde-desktop" "task-lxqt-desktop" "rsyslog"
        "gnome-shell" "gdm3" "task-cinnamon-desktop" "cinnamon"
    )
    log_info "A limpar pacotes não autorizados"
    apt_cmd purge "${pkg_del[@]}" -y
    clean_systeam
}

usage() {
    cat << EOF
Uso: $(basename "$0") <comando> [parâmetro]
Comandos Principais:
  clean          Limpeza de sistema e correção do APT.
  full           Instalação COMPLETA (Transforma Debian em Windoze).

Gestão de Componentes:
  install <componente>
      Opções: base, gui, ocs, crontab, themes, splash, 
              browsers, office, logrotate, ysoft, users

  remove <componente>
      Opções: gui, ocs, crontab, themes, splash, 
              chrome, onlyoffice, ysoft

Exemplos:
  $(basename "$0") install gui
  $(basename "$0") remove ysoft
EOF
    exit 1
}

# Faz o reset aos utilizadores
install_users() {
    local mgr="$AEVH_BIN/user-manage"
    [[ ! -x "$mgr" ]] && { log_warn "$mgr não encontrado"; return 1; }
    "$mgr" reset aluno
    "$mgr" reset professor
}

main() {
    local COMMAND="${1:-}" PARAM="${2:-}"
    is_root && OPT="como root" || OPT="" 
    log_info "A executar windoze $COMMAND $PARAM $OPT"
    [[ -z "$COMMAND" ]] && usage
    getroot "$COMMAND" "$PARAM"
    case "$COMMAND" in
        "clean") clean_system ;;
        "install")
            case "$PARAM" in
                "base") install_base ;;
                "gui") install_gui ;;
                "office") install_office ;;
                "ocs") install_ocs ;;
                "crontab") install_crontab ;;
                "themes") install_themes ;;
                "splash") install_splash ;;
                "browsers") install_browsers ;;
                "logrotate") install_logrotate ;;
                "ysoft") install_ysoft ;;
                "users") install_users ;;
                *) log_error "$0 $1 $2 - Opção inválida" ;;
            esac
        ;;
        "remove")
            case "$PARAM" in
                "ysoft") remove_ysoft ;;
                "chrome") remove_chrome ;;
                "onlyoffice") remove_onlyoffice ;;
                "gui") remove_gui ;;
                "ocs") remove_ocs ;;
                "crontab") remove_crontab ;;
                "themes") remove_themes ;;
                "splash") remove_splash ;;
                *) log_error "$0 $1 $2 - Opção inválida" ;;
            esac
        ;;
        "full")
            install_base
            install_gui
            install_ocs
            install_crontab
        #	install_logrotate
            install_themes
            install_splash
            install_browsers
            install_office
            [[ -x "$AEVH_BIN"/profile-menu ]] && "$AEVH_BIN"/profile-menu 
            purge
            log_info "Instalação concluída"
            ;;
        *)
            log_error "Comando desconhecido"
            usage
        ;;
    esac
}

main "$@"
