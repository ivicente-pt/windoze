AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || { echo "Falha a carregar lib AEVH"; exit 1; }

# Habilita repositórios
enable_repos() {
    local list="/etc/apt/sources.list" dst="/etc/apt/sources.list.d/aevh-sources.list" src=""
    is_debian12 && src="$AEVH_CONF/apt/bookworm.list"
    is_debian13 && src="$AEVH_CONF/apt/trixie.list"
    [[ -z "$src" ]] && { log_warn "SO não reconhecido"; return 1; }
    [[ ! -f "$src" ]] && { log_warn "Ficheiro não encontrado: $src"; return 1; }
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "# O conteúdo foi movido para $dst" > "$list"
    log_info "A atualizar repositórios"
    apt_update
}

# Cria e configura o utilizador master
install_master() {
    local user="master" pass_file="$AEVH_DATA/user/master.psw" groups="sudo,plugdev,netdev,audio,video"
    if id -u "$user" >/dev/null 2>&1; then 
        log_info "O utilizador $user já existe. A atualizar grupos..."
        usermod -aG "$groups" "$user" 2>/dev/null
    else
        [[ ! -f "$pass_file" ]] && { log_error "Ficheiro de password não encontrado: $pass_file"; return 1; }
        if useradd -m -s /bin/bash -G "$groups" "$user"; then
            echo "$user:$(<"$pass_file")" | chpasswd -e
            log_info "Utilizador criado: $user"
        else
            log_error "Falha ao criar utilizador: $user"
            return 1
        fi
    fi
    local home
    home=$(get_home "$user")
    [[ -z "$home" ]] && { log_error "Não foi possível determinar a home do $user"; return 1; }
    # Desktop
    local desktop=""
    if command -v xdg-user-dir >/dev/null 2>&1; then
        runuser -u "$user" -- xdg-user-dirs-update
        desktop=$(runuser -u "$user" -- xdg-user-dir DESKTOP)
    fi
    if [[ -z "$desktop" || "$desktop" == "$home" ]]; then
        desktop="$home/Desktop"
        mkdir -p "$desktop"
    fi
    if [[ "$desktop" != "$home/Desktop" ]]; then
        if [[ ! -e "$home/Desktop" ]]; then
            ln -s "$desktop" "$home/Desktop"
            chown -h "$user:$user" "$home/Desktop"
        fi
    fi
    copy_check "$AEVH_DATA/desktop/Windoze.desktop" "$desktop/"
    # Applications
    local apps="$home/.local/share/applications"
    mkdir -p "$apps"
    compgen -G "$AEVH_DATA/desktop/*.desktop" > /dev/null && \
        for f in "$AEVH_DATA/desktop/"*.desktop; do
            copy_check "$f" "$apps/"
        done
    # Permissões
    chown "$user:$user" "$desktop"
    chown -R "$user:$user" "$desktop" "$home/.local"
    log_info "Utilizador $user configurado"
}

