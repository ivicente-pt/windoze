#!/usr/bin/env bash
set -euo pipefail

# auto-apt-proxy v1.1 - 2026-03-24
# Definir o proxy para usar com o apt, se estiver disponível

# Nota:
# é preciso usar a diretiva "PassThroughPattern: .*" no ficheiro acng.conf no apt-cacher-ng

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

main() {
	get_root "$@"

	local ip port proxy proxyconf="/etc/apt/apt.conf.d/02-apt-proxy.conf"

	log_info "A procurar um proxy APT disponível..."
	for proxy in "${APT_PROXIES[@]}"; do
		ip="${proxy%%:*}"
		port="${proxy##*:}"
		if test_port "$ip" "$port"; then
			{
				echo "Acquire::http::Proxy \"http://$ip:$port\";"
				echo "Acquire::https::Proxy \"http://$ip:$port\";"
			} > "$proxyconf"
			log_bye "Proxy configurado com sucesso: $ip:$port"
		fi
		log_info "Proxy $ip:$port não respondeu"
	done
	log_warn "Nenhum proxy APT disponível"
	[[ -f "$proxyconf" ]] && rm -f "$proxyconf"
	log_info "APT em ligação direta."
}

main "$@"
