#!/usr/bin/env bash
set -euo pipefail

# shutdown-notify v1.02 - 2025-11-22
# Verifica se há um encerramento a decorrer. Se faltar um múltiplo de 5 ou menos de 5 minutos
# para o encerramento, notifica o utilizador, dando a opção de cancelar o encerramento em curso.
# Se for indicado um parâmetro (qualquer) mostra o notify agora.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
# shellcheck source=/dev/null
source "$PROJECT_ROOT/lib/aevh-tools.sh"

SHUTFILE=/run/systemd/shutdown/scheduled

# Se o ficheiro não existe termina aqui o script
[[ ! -f "$SHUTFILE" ]] && exit 0

# Main

# shellcheck source=/dev/null
source "$SHUTFILE"
TARGET_SEC=$((USEC / 1000000))
NOW_SEC=$(date +%s)
DIFF_SEC=$((TARGET_SEC - NOW_SEC))

[[ "$DIFF_SEC" -lt 0 ]] && exit 0
MIN=$((DIFF_SEC / 60))
if [[ -n "$1" || "$MIN" -lt 5 || $((MIN % 5)) -eq 0 ]]; then
    log "Encerramento agendado detetado para daqui a $MIN minutos."
    
    AVISO="O sistema vai encerrar dentro de $MIN minutos!"
    BTN_OK="Ok, continuar com o encerramento"
    BTN_CANCEL="Cancelar encerramento"

    ANS=$(notify -w -u critical -A "$BTN_OK" -A "$BTN_CANCEL" "Atenção: $AVISO")

    [[ -z "$ANS" ]] && bye "User -> Sem resposta (timeout)."

    [[ "$ANS" == "0" || "$ANS" == "$BTN_OK" ]] && bye "User -> Escolheu prosseguir com o encerramento."

    log "Utilizador solicitou cancelamento do encerramento."
    OUT=$(/usr/sbin/shutdown -c 2>&1)
    
    if [[ ! -f "$SHUTFILE" ]]; then
        notify "Informação:" "Encerramento cancelado com sucesso."
        log "Encerramento cancelado."
    else
        notify "Atenção:" "Não foi possível cancelar o encerramento!"
        error "Falha ao cancelar encerramento: $OUT"
    fi
fi
