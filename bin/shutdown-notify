#!/usr/bin/env bash
set -euo pipefail

# shutdown-notify v1.1.1 - 2026-04-07

# Verifica se há um encerramento a decorrer. Se faltar um múltiplo de 5 ou menos de 5 minutos
# para o encerramento, notifica o utilizador, dando a opção de cancelar o encerramento em curso.
# Se for indicado um parâmetro (qualquer) mostra o notify agora.

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB"
[[ "$AEVH_LIB_LOADED" != "1" ]] && { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

main() {
    local shutfile="/run/systemd/shutdown/scheduled"
    local target_sec now_sec diff_sec min usec force_notify="${1:-}"
    local btn_ok="ok" btn_cancel="cancel" ans out aviso user_name user_id
    local notify_all="${AEVH_BIN}/notify-all"
    [[ ! -f "$shutfile" ]] && exit 0
    usec=$(grep -Po '^USEC=\K[0-9]+' "$shutfile" || true)
    [[ -z "$usec" ]] && exit 0

    target_sec=$((usec / 1000000))
    now_sec=$(date +%s)
    diff_sec=$((target_sec - now_sec))

    [[ "$diff_sec" -lt 0 ]] && exit 0
    min=$((diff_sec / 60))
    if [[ -n "$force_notify" || "$min" -le 5 || $((min % 5)) -eq 0 ]]; then
        user_name=$(who | awk '{print $1}' | head -n1)
        [[ -z "$user_name" ]] && { log_error "Nenhum utilizador gráfico detetado."; exit 0; }
        user_id=$(id -u "$user_name")
        
        aviso="O sistema vai encerrar dentro de $min minutos!"
        log_info "Notificando $user_name: $aviso"

        ans=$(sudo -u "$user_name" \
              DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$user_id/bus" \
              notify-send -w -u critical \
              -A "$btn_ok=Ok, continuar" \
              -A "$btn_cancel=Cancelar encerramento" \
              "Atenção" "$aviso")

        case "$ans" in
            "$btn_cancel")
                log_info "Utilizador $user_name solicitou cancelamento."
                if out=$(/usr/sbin/shutdown -c 2>&1); then
                    [[ -x "$notify_all" ]] && "$notify_all" "Informação: Encerramento cancelado por $user_name."
                    log_info "Encerramento cancelado com sucesso."
                else
                    log_error "Falha ao cancelar: $out"
                fi
                ;;
            "$btn_ok") log_info "User escolheu prosseguir." ;;
            *) log_info "Notificação fechada ou ignorada (Ação: $ans)." ;;
        esac
    fi
}

main "$@"
