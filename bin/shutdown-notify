#!/usr/bin/env bash
set -euo pipefail

# shutdown-notify v1.1 - 2026-03-24

# Verifica se há um encerramento a decorrer. Se faltar um múltiplo de 5 ou menos de 5 minutos
# para o encerramento, notifica o utilizador, dando a opção de cancelar o encerramento em curso.
# Se for indicado um parâmetro (qualquer) mostra o notify agora.

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

main() {
    local shutfile="/run/systemd/shutdown/scheduled"
    local target_sec now_sec diff_sec min usec force_notify="${1:-}" aviso btn_ok btn_cancel ans out
    [[ ! -f "$shutfile" ]] && exit 0
    usec=$(grep -Po '^USEC=\K[0-9]+' "$shutfile" || true)
    [[ -z "$usec" ]] && exit 0

    target_sec=$((usec / 1000000))
    now_sec=$(date +%s)
    diff_sec=$((target_sec - now_sec))

    [[ "$diff_sec" -lt 0 ]] && exit 0
    min=$((diff_sec / 60))
    if [[ -n "$force_notify" || "$min" -lt 5 || $((min % 5)) -eq 0 ]]; then
        aviso="O sistema vai encerrar dentro de $min minutos!"
        btn_ok="Ok, continuar com o encerramento"
        btn_cancel="Cancelar encerramento"
        log_info "$aviso"
        ans=$(notify -w -u critical -A "$btn_ok" -A "$btn_cancel" "Atenção: $aviso")

        [[ -z "$ans" ]] && log_bye "User -> Sem resposta (timeout)."
        [[ "$ans" == "0" || "$ans" == "$btn_ok" ]] && log_bye "User -> Escolheu prosseguir com o encerramento."

        log_info "Utilizador solicitou cancelamento do encerramento."
        if out=$(/usr/sbin/shutdown -c 2>&1); then
            notify "Informação:" "Encerramento cancelado com sucesso."
            log_info "Encerramento cancelado."
        else
            notify "Atenção:" "Não foi possível cancelar o encerramento!"
            log_error "Falha ao cancelar encerramento: $out"
        fi
    fi
}

main "$@"