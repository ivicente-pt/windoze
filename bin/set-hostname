#!/usr/bin/env bash
set -euo pipefail

# set-hostname v1.1 - 2026-04-07
# Altera o hostname da máquina de forma interativa

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || true
[[ "${AEVH_LIB_LOADED:-0}" != "1" ]] && { echo "Falha a carregar $AEVH_LIB" >&2 ; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

main() {
    get_root "$@"
    local ans title="Configuração de Hostname" question="Indique o novo hostname desta máquina:" current
    current=$(trim "$(< /etc/hostname)")

    # Loop principal
    while true; do
        if ! ans=$(ui_get_input "$title" "$question" "$current"); then
            log_bye "Alteração cancelada."
        fi
        ans=$(trim "$ans")
        if ! is_valid_hostname "$ans"; then
            ui_show_msg "Erro" "O hostname '$ans' é inválido.\nUse apenas letras, números e hífenes." 0 0
            question="Hostname inválido. Tente de novo:"
            continue
        fi
        [[ "$ans" == "$current" ]] && log_bye "O hostname não foi alterado ($ans)."
        if [[ -f /etc/hosts && "$current" != "localhost" ]]; then
            safe_current="${current//./\.}"
            sed -i "s/\b${safe_current}\b/${ans}/g" /etc/hosts
        fi
        echo "$ans" > /etc/hostname 
        if command -v hostnamectl >/dev/null; then
            hostnamectl set-hostname "$ans"
        else
            hostname "$ans"
        fi
                
        log_bye "Hostname alterado para '$ans'."
    done
}

main "$@"
