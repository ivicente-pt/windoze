#!/usr/bin/env bash
set -euo pipefail

# set-hostname v1.04 - 2025-12-11
# Altera o hostname da máquina de forma interativa

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
source "$PROJECT_ROOT/lib/aevh-tools.sh"


getroot "$@"

! command -v dialog >/dev/null && { echo "A instalar dependência: dialog..."; apt_install dialog; } 

TITLE="Configuração de Hostname"
QUESTION="Indique o novo hostname desta máquina:"
CURRENT=$(trim "$(< /etc/hostname)")

# Loop principal
while true; do
    ANS=$(dialog --title "$TITLE" --inputbox "$QUESTION" 10 50 "$CURRENT" 2>&1 >/dev/tty)
    [[ $? -ne 0 ]] && { warn "Alteração cancelada."; break; }
    ANS=$(trim "$ANS")
    !  is_valid_hostname "$ANS" && {
        dialog --title "Erro" --msgbox "O hostname '$ANS' é inválido.\nUse apenas letras, números e hífenes." 0 0
    	QUESTION="Hostname inválido. Tente de novo:"
        continue
    }
    [[ "$ANS" == "$CURRENT" ]] && { info "O hostname não foi alterado ($ANS)."; break; }
    [[ -f /etc/hosts ]] && sed -i "s/\b$CURRENT\b/$ANS/g" /etc/hosts
    echo "$ANS" > /etc/hostname 
    if command -v hostnamectl >/dev/null; then
        hostnamectl set-hostname "$ANS"
    else
        hostname "$ANS"
    fi
            
    info "Hostname alterado para '$ANS'."
    break
done

