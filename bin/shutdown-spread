#!/usr/bin/env bash
set -euo pipefail

# shutdown-spread v1.03 - 2026-03-24
# Agenda um comando de shutdown para um valor aleatório
# O pré-definido é entre 15 e 29 minutos [15, 30[

main() {
    local start="${1:-15}" delta="${2:-15}" min

    [[ ! "$start" =~ ^[0-9]+$ ]] && start=15 || true
    [[ ! "$delta" =~ ^[0-9]+$ ]] || [[ "$delta" -eq 0 ]] && delta=15 || true
    min=$(( 10#$start + (RANDOM % 10#$delta)))
    echo "Encerramento agendado para daqui a ${min} minutos."
    /usr/sbin/shutdown -h +"$min"
}

main "$@"
