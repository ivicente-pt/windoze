#!/usr/bin/env bash
set -euo pipefail

# user-options v1.1 - 2026-03-24

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || { echo "Falha a carregar lib AEVH"; exit 1; }

# Definições visuais
readonly WALLPAPER="/usr/share/backgrounds/Windoze/Win11.jpg"
readonly XFWM="Default-hdpi"
readonly THEME="Fluent-round-Light-compact"
readonly ICON="wow64-Light"
readonly FONT="Arimo Regular 10"
LOGO="distributor-logo-windows"

set_xfce4_options() {
    log_info "A aplicar as opções visuais do XFCE4"
    
    xf_set() { xfconf-query -c "$1" -p "$2" -s "$3" --create -t "${4:-string}" || true; }
    
    local prop properties key path
    properties=$(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep "last-image$" || true)
    if [[ -z $properties ]]; then
        log_warn "Nenhuma propriedade de monitor encontrada. O XFCE já iniciou?"
    else
        for prop in $properties; do
            xf_set "xfce4-desktop" "$prop" "$WALLPAPER"
        done
    fi

    xf_set "xfwm4"          "/general/theme"        "$XFWM"
    xf_set "xfwm4"          "/general/use_compositing" false    bool
    xf_set "xsettings"      "/Net/ThemeName"        "$THEME"
    xf_set "xsettings"      "/Net/IconThemeName"    "$ICON"
    xf_set "xsettings"      "/Gtk/FontName"         "$FONT"
    xf_set "xfce4-desktop"  "/desktop-icons/style"  2           int
    
    declare -A xdg_map=(
        [DESKTOP]="$HOME/Área de Trabalho"
        [DOWNLOAD]="$HOME/Transferências"
        [TEMPLATES]="$HOME/Modelos"
        [PUBLICSHARE]="$HOME/Público"
        [DOCUMENTS]="$HOME/Documentos"
        [MUSIC]="$HOME/Música"
        [PICTURES]="$HOME/Imagens"
        [VIDEOS]="$HOME/Vídeos"
    )
    for key in "${!xdg_map[@]}"; do
        path="${xdg_map[$key]}"
        [[ ! -d "$path" ]] && mkdir -p "$path"
        xdg-user-dirs-update --set "$key" "$path"
    done
    xdg-user-dirs-update
    
    #xdg-mime default nemo.desktop inode/directory application/x-gnome-saved-search
    # local panelsave="$AEVH_DATA/user/xfce4-panel-01.tar.bz2"
    # local panelsave="$AEVH_DATA/user/xfce4-panel-02.tar.bz2"
    # [[ -f "$panelsave" ]] && xfce4-panel-profiles load "$panelsave"
}

main() {
    is_root && log_critical "Este script não deve ser executado como root nem com sudo."
    set_xfce4_options
    flatpak override --user --filesystem=/media || true
    flatpak override --user --filesystem=removable-media || true
    log_info "Configuração de utilizador concluída"
}

main "$@"