#!/usr/bin/env bash
set -euo pipefail

# windoze-menu v1.05 - 2025-12-17

# executar antes de obter o root, para ter acesso ao display
xhost local:root >/dev/null 2>&1

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
source "$PROJECT_ROOT/lib/aevh-tools.sh"

WINDOZE="$AEVH_BIN/windoze"

other_ops() {
    speak "Menu de operações e teste."
    while true; do
		local TITLE="Operações individuais e de teste"
		local MENU="Escolher a operação"
		local OPT
		OPT=$(dialog --title "$TITLE" --menu "$MENU" 0 0 0 \
			"1" "Verificar proxy-cache de apt" \
			"2" "Teste de notificações (notify-all)" \
			"3" "Definir o hostname" \
			"4" "Monitores em espelho (mirror)" \
			"5" "Teste de shutdown-notify" \
			"6" "Executar o shutdown spread" \
			"7" "Limpeza de sistema" \
			"0" "Voltar"\
		3>&1 1>&2 2>&3)
		RET=$?
		[[ $RET -ne 0 || "$OPT" == "0" ]] && return 0
		case $OPT in
			"1") clear; "$AEVH_BIN"/auto-apt-proxy ;;
			"2")
				clear
				speak "A testar notificação"
				apt_install libnotify-bin 
				"$AEVH_BIN"/notify-all teste
			;;
			"3") clear; "$AEVH_BIN"/set-hostname ;;
			"4") clear; "$AEVH_BIN"/monitor-ctrl mirror ;;
			"5") clear; "$AEVH_BIN"/shutdown-notify ;;
			"6") clear; "$AEVH_BIN"/shutdown-spread ;;
			"7") clear; "$WINDOZE" clean ;;
			"0") return 0 ;;
		esac
		keywait
	done
}

# Instalar componentes
installations() {
    speak "Menu de instalações."
    while true; do
        local TITLE="Instalações"
        local MENU="Escolher a operação"
        local OPT
        OPT=$(dialog --title "$TITLE" --menu "$MENU" 0 0 0 \
            "A" "Instalação base (essencial)" \
            "B" "Interface gráfica (GUI)" \
            "C" "Crontab (tarefas agendadas)" \
            "D" "OCS Inventory Agent" \
            "E" "Temas visuais" \
            "F" "Splash screen (boot)" \
            "G" "Logrotate" \
            "H" "YSoft SafeQ Client" \
            "I" "Browsers (Firefox, Google Chrome)" \
            "J" "Office (LibreOffice, OnlyOffice)" \
            "0" "Voltar"\
		3>&1 1>&2 2>&3)
        RET=$?
        [[ $RET -ne 0 || "$OPT" == "0" ]] && return 0
        OPT=${OPT^^}
        speak "A iniciar instalação."
		case $OPT in
	    	"A") clear; "$WINDOZE" install base ;;
            "B") clear; "$WINDOZE" install gui ;;
            "C") clear; "$WINDOZE" install crontab ;;
            "D") clear; "$WINDOZE" install ocs ;;
            "E") clear; "$WINDOZE" install themes ;;
            "F") clear; "$WINDOZE" install splash ;;
            "G") clear; "$WINDOZE" install logrotate ;;
            "H") clear; "$WINDOZE" install ysoft ;;
            "I") clear; "$WINDOZE" install browsers ;;
            "J") clear; "$WINDOZE" install office ;;
        esac
        keywait
    done
}

# Desinstalar componentes
uninstallations() {
    speak "Menu de desinstalações."
    while true; do
        local TITLE="Instalações"
        local MENU="Escolher componente a remover"
		local OPT
    	OPT=$(dialog --title "$TITLE" --menu "$MENU" 0 0 0 \
            "1" "Interface gráfica" \
            "2" "Crontab" \
            "3" "OCS Agent" \
            "4" "Temas" \
            "5" "Splash screen" \
            "6" "YSoft Client" \
            "7" "Google Chrome" \
            "8" "OnlyOffice" \
            "0" "Voltar"\
		3>&1 1>&2 2>&3)
        RET=$?
        [[ $RET -ne 0 || "$OPT" == "0" ]] && return 0
        [[ "$OPT" != "0" ]] && speak "A remover componente."
		case $OPT in
            "1") "$WINDOZE" remove gui ;;
            "2") "$WINDOZE" remove crontab ;;
            "3") "$WINDOZE" remove ocs ;;
            "4") "$WINDOZE" remove themes ;;
            "5") "$WINDOZE" remove splash ;;
            "6") "$WINDOZE" remove ysoft ;;
            "7") "$WINDOZE" remove chrome ;;
            "8") "$WINDOZE" remove onlyoffice ;;
        esac
        keywait
    done
}

PATH="$PATH:$AEVH_BIN"
TITLE="Windoze - Admin - AEVH"
MENU="Menu Principal de Gestão:"

# main()
getroot "$@"
apt_install dialog
speak "Bem vindo ao sistema de gestão."
while true; do
    clear
    OPT=$(dialog --title "$TITLE" --menu "$MENU" 0 0 0 \
        "1" "Atualizar sistema" \
        "2" "Instalar componentes..." \
        "3" "Remover componentes..." \
        "4" "Gerir perfil da máquina..." \
        "5" "Gerir utilizadores..." \
        "6" "Outras operações / Testes..." \
        "0" "Sair"\
    3>&1 1>&2 2>&3)
    RET="$?"
    [[ "$RET" -ne 0 || "$OPT" == "0" ]] && { clear; speak "A sair do sistema."; exit 0; }
    case $OPT in
        "1")
            clear
            info "A atualizar e corrigir o sistema"
            apt_update
            apt_upgrade
            apt_fix
            info "Atualização concluída"
            keywait
        ;;
	"2") clear; installations ;;                                   
	"3") clear; uninstallations ;;                                  
	"4") clear; "$AEVH_BIN"/profile-menu ;;
	"5") clear; "$AEVH_BIN"/user-menu ;;                       
	"6") clear; other_ops ;;
    esac
done
