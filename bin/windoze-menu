#!/usr/bin/env bash
set -euo pipefail

# windoze-menu v1.1 - 2026-03-24

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || true
[[ "${AEVH_LIB_LOADED:-0}" != "1" ]] && { echo "Falha a carregar $AEVH_LIB" >&2 ; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || log_critical "Falha a carregar $WINDOZE_CONF"

other_ops() {
    local opt
    log_info "Menu de operações e teste."
    while true; do
		if ! opt=$(ui_select_option "Operações individuais e de teste" "Escolher a operação" \
			"Verificar proxy-cache de apt" \
			"Teste de notificações (notify-all)" \
			"Definir o hostname" \
			"Monitores em espelho (mirror)" \
			"Teste de shutdown-notify" \
			"Executar o shutdown spread" \
			"Limpeza de sistema" \
			"Voltar"); then
            return 0
        fi
        case $opt in
            "1") "$AEVH_BIN"/auto-apt-proxy ;;
            "2")
                log_info "A testar notificação"
                apt_install libnotify-bin 
                "$AEVH_BIN"/notify-all teste
            ;;
            "3") "$AEVH_BIN"/set-hostname ;;
            "4") "$AEVH_BIN"/monitor-ctrl mirror ;;
            "5") "$AEVH_BIN"/shutdown-notify ;;
            "6") "$AEVH_BIN"/shutdown-spread ;;
            "7") "$WINDOZE" clean ;;
            "8") return 0 ;;
        esac
        keywait
	done
}

# Instalar componentes
installations() {
    local opt
    log_info "Menu de instalações."
    while true; do
        if ! opt=$(ui_select_option "Instalações" "Escolher a operação" \
            "Instalação base (essencial)" \
            "Interface gráfica (GUI)" \
            "Crontab (tarefas agendadas)" \
            "OCS Inventory Agent" \
            "Temas visuais" \
            "Browsers (Firefox, Google Chrome)" \
            "Office (LibreOffice, OnlyOffice)" \
            "Criar user para provas externas" \
            "Voltar"); then
            return 0
        fi
		case $opt in
	    	"1") "$WINDOZE" install base ;;
            "2") "$WINDOZE" install gui ;;
            "3") "$WINDOZE" install crontab ;;
            "4") "$WINDOZE" install ocs ;;
            "5") "$WINDOZE" install themes ;;
            "6") "$WINDOZE" install browsers ;;
            "7") "$WINDOZE" install office ;;
            "8") setup_intuitivo ;; 
            "9") return 0 ;;
        esac
        keywait
    done
}

# Desinstalar componentes
uninstallations() {
    local opt
    log_info "Menu de desinstalações."
    while true; do
    	if ! opt=$(ui_select_option "Desinstalações" "Escolher componente a remover" \
            "Interface gráfica" \
            "Crontab" \
            "OCS Agent" \
            "Temas" \
            "Browsers" \
            "Office" \
            "Utilizador das provas externas" \
            "Voltar"); then
            return 0
        fi
		case $opt in
            "1") "$WINDOZE" remove gui ;;
            "2") "$WINDOZE" remove crontab ;;
            "3") "$WINDOZE" remove ocs ;;
            "4") "$WINDOZE" remove themes ;;
            "5") "$WINDOZE" remove browsers ;;
            "6") "$WINDOZE" remove office ;;
            "7") del_intuitivo ;;
            "8") return 0 ;;
        esac
        keywait
    done
}

setup_intuitivo() {
    local apps="/opt/aevh/apps" autostart_script="/usr/local/bin/launch-provas.sh"
    local config_dir="/home/intuitivo/.config/autostart"

    useradd -m -c "Provas externas" -s /bin/bash intuitivo
    echo "intuitivo:provas2026" | chpasswd

    mkdir -p "$apps"
    chmod "$apps"

    cat << 'EOF' > $autostart_script
#!/bin/bash
#/opt/aevh/bin/classmate.sh
"/opt/aevh/apps/Provas IAVE-0.0.12.AppImage"
xfce4-session-logout --logout
EOF
    chmod +x $autostart_script
    sudo -u intuitivo mkdir -p $config_dir
    cat << EOF > $config_dir/provas-kiosk.desktop
[Desktop Entry]
Type=Application
Exec=$autostart_script
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
Name=Kiosk Provas
Comment=Inicia a AppImage de Provas e encerra a sessão ao sair
EOF

    chown intuitivo:intuitivo $config_dir/provas-kiosk.desktop
}

del_intuitivo() {
    rm -f /usr/local/bin/launch-provas.sh
    deluser --remove-home intuitivo
}

main () {
    xhost local:root >/dev/null 2>&1 || true
    get_root "$@"
    PATH="$PATH:$AEVH_BIN"
    WINDOZE="$AEVH_BIN/windoze"
    #apt_install dialog
    log_info "Bem vindo ao sistema de gestão."
    while true; do
        if ! opt=$(ui_select_option "AEVH Windoze" "Gestão principal" \
            "Atualizar sistema" \
            "Instalar componentes..." \
            "Remover componentes..." \
            "Gerir perfil da máquina..." \
            "Gerir utilizadores..." \
            "Outras operações / Testes..." \
            "Sair"); then return 0
        fi
        case $opt in
            "1")
                log_info "A atualizar e corrigir o sistema"
                apt_update
                apt_upgrade
                apt_fix
                log_info "Atualização concluída"
            ;;
            "2") installations ;;                                   
            "3") uninstallations ;;                                  
            "4") "$AEVH_BIN"/profile-menu ;;
            "5") "$AEVH_BIN"/user-menu ;;                       
            "6") other_ops ;;
            "7") return 0 ;;
        esac
    done
}

main "$@"
