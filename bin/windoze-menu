#!/usr/bin/env bash
set -euo pipefail

# windoze-menu v1.1 - 2026-03-24

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB"
[[ "$AEVH_LIB_LOADED" != "1" ]] && { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

other_ops() {
    local opt
    log_info "Menu de operações e teste."
    while true; do
		if ! opt=$(dialog --title "Operações individuais e de teste" --menu "Escolher a operação" 0 0 0 \
			"1" "Verificar proxy-cache de apt" \
			"2" "Teste de notificações (notify-all)" \
			"3" "Definir o hostname" \
			"4" "Monitores em espelho (mirror)" \
			"5" "Teste de shutdown-notify" \
			"6" "Executar o shutdown spread" \
			"7" "Limpeza de sistema" \
			"0" "Voltar" 3>&1 1>&2 2>&3); then
            return 0
        fi
        case $opt in
            "1") clear; "$AEVH_BIN"/auto-apt-proxy ;;
            "2")
                clear
                log_info "A testar notificação"
                apt_install libnotify-bin 
                "$AEVH_BIN"/notify-all teste
            ;;
            "3") clear; "$AEVH_BIN"/set-hostname ;;
            "4") clear; "$AEVH_BIN"/monitor-ctrl mirror ;;
            "5") clear; "$AEVH_BIN"/shutdown-notify ;;
            "6") clear; "$AEVH_BIN"/shutdown-spread ;;
            "7") clear; "$WINDOZE" clean ;;
            "0") return 0 ;;
        esac
        keywait
	done
}

# Instalar componentes
installations() {
    local opt
    log_info "Menu de instalações."
    while true; do
        if ! opt=$(dialog --title "Instalações" --menu "Escolher a operação" 0 0 0 \
            "A" "Instalação base (essencial)" \
            "B" "Interface gráfica (GUI)" \
            "C" "Crontab (tarefas agendadas)" \
            "D" "OCS Inventory Agent" \
            "E" "Temas visuais" \
            "F" "Browsers (Firefox, Google Chrome)" \
            "G" "Office (LibreOffice, OnlyOffice)" \
            "0" "Voltar" 3>&1 1>&2 2>&3); then
            return 0
        fi
		case $opt in
	    	"A") clear; "$WINDOZE" install base ;;
            "B") clear; "$WINDOZE" install gui ;;
            "C") clear; "$WINDOZE" install crontab ;;
            "D") clear; "$WINDOZE" install ocs ;;
            "E") clear; "$WINDOZE" install themes ;;
            "F") clear; "$WINDOZE" install browsers ;;
            "G") clear; "$WINDOZE" install office ;;
            "0") return 0 ;;
        esac
        keywait
    done
}

# Desinstalar componentes
uninstallations() {
    local opt
    log_info "Menu de desinstalações."
    while true; do
    	if ! opt=$(dialog --title "Desinstalações" --menu "Escolher componente a remover" 0 0 0 \
            "1" "Interface gráfica" \
            "2" "Crontab" \
            "3" "OCS Agent" \
            "4" "Temas" \
            "5" "Splash screen" \
            "6" "YSoft Client" \
            "7" "Google Chrome" \
            "8" "OnlyOffice" \
            "0" "Voltar" 3>&1 1>&2 2>&3); then
            return 0
        fi
		case $opt in
            "1") "$WINDOZE" remove gui ;;
            "2") "$WINDOZE" remove crontab ;;
            "3") "$WINDOZE" remove ocs ;;
            "4") "$WINDOZE" remove themes ;;
            "5") "$WINDOZE" remove splash ;;
            "6") "$WINDOZE" remove ysoft ;;
            "7") "$WINDOZE" remove chrome ;;
            "8") "$WINDOZE" remove onlyoffice ;;
            "0") return 0 ;;
        esac
        keywait
    done
}

main () {
    xhost local:root >/dev/null 2>&1 || true
    get_root "$@"
    PATH="$PATH:$AEVH_BIN"
    WINDOZE="$AEVH_BIN/windoze"
    apt_install dialog
    log_info "Bem vindo ao sistema de gestão."
    while true; do
        clear
        if ! opt=$(dialog --title "AEVH Windoze" --menu "Gestão principal" 0 0 0 \
            "1" "Atualizar sistema" \
            "2" "Instalar componentes..." \
            "3" "Remover componentes..." \
            "4" "Gerir perfil da máquina..." \
            "5" "Gerir utilizadores..." \
            "6" "Outras operações / Testes..." \
            "0" "Sair" 3>&1 1>&2 2>&3); then return 0
        fi
        case $opt in
            "1")
                clear
                log_info "A atualizar e corrigir o sistema"
                apt_update
                apt_upgrade
                apt_fix
                log_info "Atualização concluída"
                keywait
            ;;
            "2") installations ;;                                   
            "3") uninstallations ;;                                  
            "4") "$AEVH_BIN"/profile-menu ;;
            "5") "$AEVH_BIN"/user-menu ;;                       
            "6") other_ops ;;
            "0") return 0 ;;
        esac
    done
}

main "$@"
