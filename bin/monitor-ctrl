#!/usr/bin/env bash
set -euo pipefail

# monitor-ctrl v1.2 2026-04-07

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" > /dev/null
[[ "$AEVH_LIB_LOADED" != "1" ]] && { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

# Funções auxiliares
#  get_first_connected_monitor_id() - ID do monitor
#  get_monitor_orientation() - Orientação do monitor
# Funções principais
#  cmd_help() - Mostra a ajuda
#  cmd_id() - Mostra todos os monitores ligados
#  cmd_orientation() - Devolve a orientação do monitor indicado
#  cmd_rotate() - Roda o monitor
#  cmd_mirror() - Coloca todos os monitoes em mirror, com a menor resolução suportada


# Retorna o ID do monitor ou uma string vazia se nenhum for encontrado.
get_first_connected_monitor_id() {
    xrandr | grep " connected" | grep -v "disconnected" | awk '{print $1}' | head -n1
}

# Obter a orientação atual de um monitor. Parâmetros: $1 = monitor_id
# Retorna a orientação (normal, right, inverted, left) ou string vazia.
get_monitor_orientation() {
    local monitor_id="${1:-}" flag orientation
    # shellcheck disable=SC2155
    flag=$(xrandr | grep "^${monitor_id} connected" | awk '{print $3}')
    # Para o monitor primary a orientação é a 5ª palavra, para os outros é a 4ª
    if [[ "$flag" == "primary" ]]; then
        # shellcheck disable=SC2155
        orientation=$(xrandr | grep "^${monitor_id} connected" | awk '{print $5}')
    else
        # shellcheck disable=SC2155
        orientation=$(xrandr | grep "^${monitor_id} connected" | awk '{print $4}')
    fi
    [[ "$orientation" == "(normal" ]] && orientation="normal"
    echo "$orientation"
}

# Mostra os IDs do monitores conectados
cmd_id() {
    xrandr | grep " connected" | grep -v "disconnected" | awk '{print $1}'
    return 0
}

# Devolve a orientação do monitor passado como parâmetro ou do primeiro monitor.
cmd_orientation() {
    local monitor_id="${1:-}" orientation
    [[ -z "$monitor_id" ]] && monitor_id=$(get_first_connected_monitor_id)
    [[ -z "$monitor_id" ]] && { log_warn "Nenhum monitor encontrado"; return 1; }

    # shellcheck disable=SC2155
    orientation=$(get_monitor_orientation "$monitor_id")
    [[ -z "$orientation" ]] && orientation="desconhecida"
    echo "Orientação:"
    echo "  $monitor_id: $orientation"
    return 0
}

# Roda o monitor indicado ou o primeiro monitor, para a orientação indicada ou 90º no sentido horário.
cmd_rotate() {
    local req_orientation="${1:-}" monitor_id="${2:-}"

    [[ -z "$monitor_id" ]] && monitor_id=$(get_first_connected_monitor_id)
    [[ -z "$monitor_id" ]] && log_critical "Nenhum monitor encontrado"

    # shellcheck disable=SC2155
    local orientation=$(get_monitor_orientation "$monitor_id") final_orientation=""

    if [[ -z "$req_orientation" ]]; then
        case "$orientation" in
            "normal") final_orientation="right" ;;
            "right") final_orientation="inverted" ;;
            "inverted") final_orientation="left" ;;
            *) final_orientation="normal" ;;
        esac
    else
        case "$req_orientation" in
            "normal"|"right"|"inverted"|"left")
                final_orientation="$req_orientation"
            ;;
            *)
                log_critical "Orientação inválida '$req_orientation'. Orientação possíveis: normal right inverted left"
            ;;
        esac
    fi

    echo "A rodar '$monitor_id' para '$final_orientation'."
    xrandr --output "$monitor_id" --rotate "$final_orientation"
}

cmd_mirror() {
    # Vídeo
    # Executa o comando xrandr e filtra os nomes dos monitores conectados
    local minres="" res curr_hor min_hor cmd current_sink hdmi_sink analog_sink
    local monitor monitors=($(xrandr | grep ' connected' | awk '{print $1}'))
    [[ ${#monitors[@]} -lt 2 ]] && { echo "O sistema só tem um monitor"; return 0; }
    # encontrar a menor resolução (horizontal)
    for monitor in "${monitors[@]}"; do
        # obter a resolução do monitor
        # shellcheck disable=SC2155
        res=$(xrandr | grep "^$monitor connected" | sed 's/primary //' | awk '{print $3}' | sed 's/+.*//')

        [[ -z "$res" ]] && continue
        if [[ -z "$minres" ]]; then
            minres="$res"
        else
            # shellcheck disable=SC2155
            curr_hor=$(echo "$res"|awk -Fx '{print $1}')
            # shellcheck disable=SC2155
            min_hor=$(echo "$minres"|awk -Fx '{print $1}')
            [[ "$curr_hor" -lt "$min_hor" ]] && minres="$res"
        fi
    done
    cmd="xrandr --output ${monitors[0]} --mode $minres"
    for ((i=1; i<${#monitors[@]}; i++)); do
        cmd="$cmd --output ${monitors[$i]} --mode $minres --same-as ${monitors[0]}"
    done
    eval $cmd
    # Áudio
    # shellcheck disable=SC2155
    current_sink=$(pactl get-default-sink)
    if hdmi_connected; then
        # shellcheck disable=SC2155
        hdmi_sink=$(pactl list short sinks | grep -i "hdmi" | awk '{print $2}' | head -n 1)
        [[ -n "$hdmi_sink" && "$current_sink" != "$hdmi_sink" ]] && change_audio_output "$hdmi_sink" "HDMI"
    else
        # shellcheck disable=SC2155
        analog_sink=$(pactl list short sinks | grep -i "analog" | awk '{print $2}' | head -n 1)
        [[ -n "$analog_sink" && "$current_sink" != "$analog_sink" ]] && change_audio_output "$analog_sink" "saĩda analógica"
    fi
}

# Mostra o texto de ajuda
usage() {
    echo "Uso: $(basename "$0") help | id | orientation [id] | rotate [orientation] [id]"
    echo "Controlar a orientação do(s) monitor(es)"
    echo "Comandos:"
    echo "  help                       Mostra este texto de ajuda."
    echo "  id                         Lista o ID dos monitores ligados."
    echo "  mirror                     Coloca os ecrãs em 'mirror'."
    echo "  orientation [id]           Apresenta a orientação do monitor 'id'."
    echo "                             Se omitido mostra a orientação do monitor atual."
    echo "  rotate [orientation] [id]  Roda o monitor 'id' para a orientação orientation."
    echo "                             Orientações possíveis: normal right inverted left"
    echo "                             'orientation' omitido = roda o monitor 90 graus no"
    echo "                             sentido horário."
    echo "                             'id' omitido = roda o primeiro monitor ligado."
    exit 0
}

main() {
    local cmd="${1:-}"
    cmd="${cmd,,}"

    [[ -z "$cmd" || "$cmd" == "help" ]] && usage
    shift
    case "$cmd" in
        "id") cmd_id "$@" ;;
        "orientation") cmd_orientation "$@" ;;
        "rotate") cmd_rotate "$@" ;;
        "mirror") cmd_mirror "$@" ;;
        *)
            echo "Erro: Comando desconhecido '$cmd'."
            echo ""
            usage
            ;;
    esac
}

main "$@"
