#!/usr/bin/env bash
set -euo pipefail

# user-manage v1.1 - 2026-03-24

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB"
[[ "$AEVH_LIB_LOADED" != "1" ]] && { echo "Falha a carregar lib AEVH"; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

# Matar os processos do $user
user_kill() {
    local user="${1:-}"
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    pkill -u "$user" >/dev/null 2>&1
    sleep 1
    pkill -9 -u "$user" >/dev/null 2>&1
    sleep 1
}

# Ativa o serviço de reposição do aluno no boot
ativar_limpa_aluno() {
    local serv="limpar-aluno.service" path="$AEVH_CONF/systemd/$serv" dst="/etc/systemd/system/"
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}()" 
    [[ ! -f "$path" ]] && { log_error "Serviço não encontrado: $path"; return 1; }
    copy_check "$path" "$dst" || { log_error "Erro a copiar o ficheiro do serviço"; return 1; }
    systemctl daemon-reload
    if systemctl enable limpar-aluno.service; then
        log_info "Limpeza automática ativada com sucesso"
    else
        log_error "Falha ao ativar o serviço $serv"
        return 1
    fi
}

# Desativa o serviço de reposição do aluno
desativar_limpa_aluno() {
    local serv="limpar-aluno.service" path="/etc/systemd/system/$serv"
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}()" 
    systemctl stop "$serv" 2>/dev/null
    if systemctl disable "$serv"; then
        if [[ -f "$path" ]]; then
            rm "$path"
            systemctl daemon-reload
            log_info "Limpeza automática desativada e ficheiro removido."
        else
            log_info "Limpeza automática desativada."
        fi
    else
        log_error "Falha ao desativar o serviço $serv"
        return 1
    fi
}

# Grava a pasta home do utilizador
user_save() {
    local user="${1:-}" tgz homedir mother child excludes
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    user_exists "$user" || log_critical "Utilizador $user não existe"
    tgz="$AEVH_DATA/user/$user.tgz"
    homedir=$(get_home "$user")
    mother=$(dirname "$homedir")
    child=$(basename "$homedir")
    [[ ! -d "$homedir" ]] && log_critical "Diretoria $homedir não existe"
    excludes=(
            --exclude="$child/.cache"
            --exclude="$child/.local/share/Trash"
            --exclude="$child/Transferências"
            --exclude="*.tmp"
            --exclude="*.log"
            --exclude="$child/.wine"
            --warning=no-file-changed
        )
    log_info "A salvar o perfil de $user"
    user_kill "$user"
    if tar cpf "$tgz.new" -C "$mother" -I 'pigz -9' "${excludes[@]}" "$child"; then
        log_info "Ficheiro $tgz criado com sucesso"
    else
        log_critical "Falha crítica ao criar $tgz"
    fi
    rotate_file_backup "$tgz" && rm "$tgz"
    if mv "$tgz.new" "$tgz"; then
        chown master:master "$tgz"
        log_info "Perfil de $user atualizado e backups rodados"
    else
        log_critical "Erro ao finalizar $tgz"
    fi
}

# Elimina o utilizador $1
user_del () {
    local user="${1:-}"
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    user_exists "$user" || return 0
    log_info "A remover $user"
    user_kill "$user"
    deluser --remove-home "$user" >/dev/null 2>&1 || log_error "Falha ao remover $user."
    user_exists "$user" && userdel -r "$user" >/dev/null 2>&1
    return 0
}

# Adiciona o utilizador $1
user_add () {
    local pass passfile user="${1:-}" groups="audio,video,plugdev,floppy"
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    log_info "A adicionar $user"
    [[ -z "$user" ]] && return 1
    passfile="$AEVH_DATA/user/$user.psw"
    [[ ! -f "$passfile" ]] && { log_error "Ficheiro de password não encontrado: $passfile"; return 1; }
	pass=$(cat "$passfile")
    [[ -z "$pass" ]] && { log_error "O ficheiro de password está vazio"; return 1; }
    getent group netdev >/dev/null && groups+=",netdev"
    useradd -m -p "$pass" -c "${user^}" -s /bin/bash -G "$groups" "$user" || { log_warn "Não consegui adicionar o utilizador $user"; return 1; } 
    log_info "Utilizador $user criado"
    return 0
}

set_xfce_session() {
    local user="${1:-}" user_home user_group dmrc_file session_name 
    local session_file="/usr/share/xsessions/xfce.desktop" accounts_dir="/var/lib/AccountsService/users"
    [[ -z "$user" ]] && { log_error "set_xfce_session(): Nome de utilizador não fornecido." >&2; return 1; }
    user_exists "$user" || { log_error "O utilizador '$user' não existe." >&2; return 1; }
    [[ ! -f "$session_file" ]] && { log_error "Sessão XFCE não encontrada em $session_file. Instale o xfce4 primeiro." >&2; return 1; }
    session_name=$(basename "$session_file" .desktop)
    log_info "A configurar ambiente XFCE para $user..."
    accounts_file="$accounts_dir/$user"
    mkdir -p "$accounts_dir"
    cat << EOF > "$accounts_file"
[org.freedesktop.DisplayManager.AccountsService]
BackgroundFile='/usr/share/backgrounds/Windoze/Win11.jpg'

[User]
Session=
XSession=xfce
Icon=/home/$user/.face
SystemAccount=false
EOF
    user_home=$(get_home "$user")
    dmrc_file="$user_home/.dmrc"
    {
        echo "[Desktop]"
        echo "Session=$session_name"
    } > "$dmrc_file"
    user_group=$(id -gn "$user")
    chown "$user:$user_group" "$dmrc_file"
    chmod 644 "$dmrc_file"

    systemctl is-active --quiet accounts-daemon && systemctl restart accounts-daemon
    echo "SUCESSO: Ambiente de $user alterado para $session_name."
    return 0
}

user_restore_fast() {
    local user="${1:-}" infile homedir mother autostart
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    log_info "A repor o perfil do $user"
    infile="$AEVH_DATA/user/$user.tgz"
    [[ -f "$infile" ]] || { log_error "Perfil $infile não encontrado"; return 1; }
    homedir=$(get_home "$user")
    mother=$(dirname "$homedir")
    mkdir -p "$mother"
    user_kill "$user"
    rm -rf "$homedir"
    tar xzf "$infile" -C "$mother" || { log_error "Não consegui descomprimir $infile"; return 1; }
    chown -R "$user":"$user" "$homedir"
    autostart="$homedir/.config/autostart"
    mkdir -p "$autostart"
    copy_check "$AEVH_DATA/desktop/monitor-mirror.desktop" "$autostart/"
    copy_check "$AEVH_DATA/desktop/user-options.desktop" "$autostart/"
    copy_check "$AEVH_DATA/desktop/Picom.desktop" "$autostart/"
    set_xfce_session "$user"
    log_info "Utilizador $user restaurado"
}
# Repõe a pasta home do user $1
user_restore() {
    local user="${1:-}" winefile homedir    
    [[ -z "$user" ]] && return 1
    log_info "A repor o perfil do $user"
    winefile="$AEVH_DATA/user/wine.tgz"
    homedir=$(get_home "$user")
    tar xzf "$winefile" -C "$homedir" || log_error "Não consegui descomprimir os ficheiros do Wine."
    chown -R "$user":"$user" "$homedir"
}

# Apaga e volta a criar o user $1
user_reset() {
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    local user="${1:-}"
    [[ -z "$user" ]] && { log_warn "user_reset(): Não foi indicado o utilizador"; return 1; } 
    user_del "$user" || { log_warn "user_reset(): Não consegui eliminar $user"; return 1; }
    user_add "$user" || { log_warn "user_reset(): Não consegui adicionar $user"; return 1; }
    user_restore "$user"
}

# Definir temas visuais do $user
user_set_options() {
    local user="${1:-}"
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    [[ -z "$user" ]] && return 0
    user_kill "$user"
    runuser -u "$user" -- dbus-launch --exit-with-session bash "$AEVH_BIN/user-options"
}

# Ajuda
usage() {
    cat << EOF
Uso: $(basename "$0") <operação> <utilizador> [fast]

O parâmetro obrigatório <operação> pode ser:
    save        Faz uma cópia da homedir do utilizador.
    del         Elimina o utilizador e todos os ficheiros.
    add         Adiciona o utilizador ao sistema.
    restore     Restaura a homedir a partir de uma cópia.
    reset       Elimina, Recria e Restaura o utilizador (Full Reset).
    options     Define opções visuais e associações de ficheiros Office.
    clean_on    Ativa a limpeza automática no arranque (apenas 'aluno').
    clean_off   Desativa a limpeza automática.

Parâmetros:
    utilizador  Nome do utilizador (ex: aluno, professor).
    fast        (Opcional) Restauro rápido.
EOF
}

main() {
    [[ $DEBUG -eq 1 ]] && log_info "${FUNCNAME[1]}() -> ${FUNCNAME[0]}(): $*" 
    [[ "$#" -lt 2 ]] && { usage; exit 0; }
    get_root "$@"
    local COMM="${1:-}" USER="${2:-}" FAST="${3:-}"

    case "$COMM" in
        "save") user_save "$USER" ;;
        "del") user_del "$USER" ;;
        "add") user_add "$USER" ;;
        "restore") user_restore "$USER" "$FAST" ;;
        "reset") user_reset "$USER" "$FAST" ;;
        "options") user_set_options "$USER" ;;
        "clean_on")
            if [[ "$USER" == "aluno" ]]; then
                ativar_limpa_aluno
            else
                log_warn "Utilizador '$USER' não suportado na autolimpeza"
            fi
        ;;
        "clean_off")
            if [[ "$USER" == "aluno" ]]; then
                desativar_limpa_aluno
            else
                log_warn "Utilizador '$USER' não suportado na autolimpeza"
            fi
        ;;
        *) usage ;;
    esac
}

main "$@"
