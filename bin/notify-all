#!/usr/bin/env bash
set -euo pipefail

# notify-all v1.1 - 2026-04-07
# Envia uma notificação a todos os utilizadores logados na interface gráfica

main() {
    local session_id session_type user_uid user_name _rest
    [[ $EUID -ne 0 ]] && { echo "Este script tem de ser executado como root."; exit 1; }

    command -v notify-send >/dev/null 2>&1 || { echo "notify-send não encontrado. Instale libnotify-bin."; exit 1; }

    # Lista todas as sessões. O grep filtra apenas sessões ativas com user
    loginctl list-sessions --no-legend | while read -r session_id user_uid user_name _rest; do

        session_type=$(loginctl show-session -p Type --value "$session_id")
        [[ "$session_type" != "x11" ]] && [[ "$session_type" != "wayland" ]] && continue

        DBUS_ADDRESS="unix:path=/run/user/${user_uid}/bus"
        DISPLAY_ID=$(loginctl show-session -p Display --value "$session_id")
        DISPLAY_ID=${DISPLAY_ID:-:0}

        [[ -S "/run/user/${user_uid}/bus" ]] && runuser -u "$user_name" -- env \
            DISPLAY="$DISPLAY_ID" \
            DBUS_SESSION_BUS_ADDRESS="$DBUS_ADDRESS" \
            /usr/bin/notify-send -i "dialog-information" "Mensagem do sistema" "$*"
    done
}

main "$@"
