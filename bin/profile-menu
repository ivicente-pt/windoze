#!/usr/bin/env bash
set -euo pipefail

# profile-menu v1.1 - 2026-04-07

AEVH_LIB="/opt/aevh/lib/aevh-lib.sh"
[[ -f "$AEVH_LIB" ]] && source "$AEVH_LIB" || true
[[ "${AEVH_LIB_LOADED:-0}" != "1" ]] && { echo "Falha a carregar $AEVH_LIB" >&2 ; exit 1; }

WINDOZE_CONF="/opt/aevh/conf/windoze.conf"
[[ -f "$WINDOZE_CONF" ]] && source "$WINDOZE_CONF" || { echo "Falha a carregar $WINDOZE_CONF"; exit 1; }

readonly PKG_EB1=( openboard )
readonly FLAT_EB1=(
    org.gcompris.GCompris
    org.tuxpaint.Tuxpaint
    edu.mit.Scratch
    org.tux4kids.tuxmath
    org.stellarium.Stellarium
    org.kde.kigo
    com.github.maoschanz.drawing
    org.tux4kids.tuxtype
    org.kde.blinken
)

readonly PKG_EB23S=(
)
readonly FLAT_EB23S=(
    org.gimp.GIMP
    org.inkscape.Inkscape
    org.audacityteam.Audacity
    org.geogebra.GeoGebra
    org.thonny.Thonny
    org.kde.kdenlive
    org.blender.Blender
    org.freecad.FreeCAD
    com.visualstudio.code
    cc.arduino.IDE2
    org.kde.krita
)

readonly PKG_TIC=(
    "dia"
)
readonly FLAT_TIC=(
    org.gimp.GIMP
    org.inkscape.Inkscape
    org.audacityteam.Audacity
    org.kde.kdenlive
    org.blender.Blender
    org.kde.krita

    com.visualstudio.code
    cc.arduino.IDE2
    org.thonny.Thonny
    edu.mit.Scratch

    org.geogebra.GeoGebra
    org.freecad.FreeCAD
    org.stellarium.Stellarium
)

setup_common() {
    clear
    "$AEVH_BIN"/set-hostname
    log_info "A atualizar repositórios e sistema..."
    apt_update && apt_upgrade
    flatpak_init
    flatpak override --system --filesystem=/media --filesystem=removable-media || true
}

op_user() {
    # $1 = op (del, add, reset, restore, clean_on, clean_off)
    # $2 = user (aluno, professor, master)
    local op="${1:-}" user="${2:-}"
    [[ -z "$op" ]] && return 0
    "$AEVH_BIN/user-manage" "$op" "$user"
}

# Uso: desktop_icons "aluno" "org.gimp.GIMP" "org.audacityteam.Audacity"
desktop_icons() {
    local user="${1:-}"
    shift
    local id ids=("$@") user_desktop source
    user_desktop=$(getent passwd "$user" | cut -d: -f6)"/Área de Trabalho"

    # Se a pasta não existir (ex: sistema em inglês), tenta "Desktop"
    [[ ! -d "$user_desktop" ]] && user_desktop=$(getent passwd "$user" | cut -d: -f6)"/Desktop"
    [[ ! -d "$user_desktop" ]] && { log_error "Pasta Desktop não encontrada para $user"; return 1; }

    log_info "A criar atalhos no ambiente de trabalho de $user..."

    for id in "${ids[@]}"; do
        source="/var/lib/flatpak/exports/share/applications/$id.desktop"

        [[ ! -f "$source" ]] && source="/usr/share/applications/$id.desktop"

        if [[ -f "$source" ]]; then
            cp "$source" "$user_desktop/"
            chown "$user:$user" "$user_desktop/$id.desktop"
            chmod +x "$user_desktop/$id.desktop"
            gio set "$user_desktop/$id.desktop" metadata::xfce-exe-checksum "$(sha256sum "$source" | awk '{print $1}')" 2>/dev/null || true
        else
            log_warn "Ícone não encontrado: $id"
        fi
    done
}

# --- Perfis ---

perfil_base() {
    ui_confirm_action "Confirmar" "Limpar o sistema? (Remove os pacotes de software)" || return 1
    setup_common
    apt_purge "${PKG_EB1[@]}" "${PKG_EB23S[@]}" "${PKG_TIC[@]}"
    flatpak uninstall --all -y
    op_user clean_off aluno
    op_user del aluno
    op_user del professor
}

perfil_sala_eb1 () {
    ui_confirm_action "Confirmação" "Aplicar Perfil Sala de Aula EB1/JI?" || return 1
    setup_common
    log_info "A instalar pacotes EB1/JI..."
    apt_install "${PKG_EB1[@]}"
    flatpak_install "${FLAT_EB1[@]}"
    op_user clean_off aluno
    op_user reset aluno
    op_user reset professor
    desktop_icons "aluno" "${FLAT_EB1[@]}" "${PKG_EB1[@]}"
}

perfil_sala_eb23s () {
    ui_confirm_action "Confirmação" "Aplicar Perfil Sala de Aula EB2/3/S?" || return 1
    setup_common
    log_info "A instalar pacotes EB23S..."
    apt_install "${PKG_EB23S[@]}"
    flatpak_install "${FLAT_EB23S[@]}"
    op_user clean_off aluno
    op_user reset aluno
    op_user reset professor
    desktop_icons "aluno" "${FLAT_EB23S[@]}" "${PKG_EB23S[@]}"
}

perfil_sala_profs () {
    ui_confirm_action "Confirmação" "Aplicar Perfil Sala de Professores?" || return 1
    setup_common
    log_info "A instalar software de impressão."
    "$AEVH_BIN/windoze" install ysoft
    op_user clean_off aluno
    op_user del aluno
    op_user reset professor
    log_info "Perfil de professores concluído."
}

perfil_sala_tic () {
    ui_confirm_action "Confirmação" "Aplicar Perfil Sala TIC?" || return 1
    setup_common
    log_info "A instalar ferramentas TIC..."
    apt_install "${PKG_TIC[@]}"
    flatpak_install "${FLAT_TIC[@]}"
    op_user clean_on aluno
    op_user reset aluno
    op_user del professor
    log_info "Perfil Sala TIC configurado."
}

perfil_biblioteca () {
    ui_confirm_action "Confirmação" "Aplicar Perfil Biblioteca?" || return 1
    setup_common
    log_info "A instalar conjunto completo..."
    apt_install "${PKG_EB1[@]}" "${PKG_EB23S[@]}" "${PKG_TIC[@]}"
    flatpak_install "${FLAT_EB1[@]}" "${FLAT_EB23S[@]}" "${FLAT_TIC[@]}"
    op_user clean_on aluno
    op_user reset aluno
    op_user del professor
    log_info "Biblioteca configurada."
}

main() {
    get_root "$@"
    local opt title="Definir perfil da máquina"
    while true; do
        if ! opt=$(ui_select_option "$title" "Escolha o perfil pretendido:" \
            "Perfil: Sala de aula EB1/JI" \
            "Perfil: Sala de aula EB23S" \
            "Perfil: Sala de professores/DTs" \
            "Perfil: Sala TIC (Alunos)" \
            "Perfil: Biblioteca (Alunos)" \
            "Perfil: Limpeza (remove tudo)"  \
            "Sair"); then
            log_bye "Menu encerrado."
        fi
        case $opt in
            "1") perfil_sala_eb1 ;;
            "2") perfil_sala_eb23s ;;
            "3") perfil_sala_profs ;;
            "4") perfil_sala_tic ;;
            "5") perfil_biblioteca ;;
            "6") perfil_base ;;
            "7") log_bye "Menu encerrado" ;;
        esac
        ui_show_msg "Sucesso" "Operação concluída com êxito!"
    done
}

main "$@"
